{
  "name": "barzar-demo",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && ELECTRON_DEV=1 electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.16.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2",
    "vite": "^5.0.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.barzar.game",
    "productName": "Barzar",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    }
  }
}
